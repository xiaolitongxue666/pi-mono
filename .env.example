# Copy to repo root `.env` (gitignored). Never commit real keys.
#
# Git Bash (recommended): ./start-pi.sh
#   - Loads this file, enables proxy if USE_PROXY=1, and passes -e extensions/volc-ark/index.ts.
# Or: ./pi-test.sh also loads `.env` when present (no --no-env).
# Volc / 方舟 needs that extension; without start-pi.sh use:
#   ./pi-test.sh -e extensions/volc-ark/index.ts
#
# Optional proxy (same shell as pi): USE_PROXY=1 ./start-pi.sh
# Or set http_proxy / HTTPS_PROXY yourself (undici respects EnvHttpProxyAgent).

# --- Volcengine ARK (方舟) — use either VOLC_API_KEY or ARK_API_KEY ---
VOLC_API_KEY=
# ARK_API_KEY=

# OpenAI-compatible base (optional; default is Beijing ARK)
VOLC_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Inference endpoint ID (must start with ep-). You can use either name:
VOLC_ARK_ENDPOINT=ep-
# DEFAULT_MODEL=ep-

# Optional second endpoint (e.g. R1)
# VOLC_ARK_ENDPOINT_R1=ep-

# Troubleshooting (Volc ARK)
# - HTTP 404 mentioning "ep-": use the full endpoint id from the Ark console, not placeholder "ep-" alone.
# - See docs/dev-local-setup.md for npm spawn on Windows, husky, and Vitest notes.

